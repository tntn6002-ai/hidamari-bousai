# Supabase（フェーズ1 Step 3以降で必要）
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Web Push VAPID（フェーズ1 Step 7: 通知機能）
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key   # サーバーサイドのみ。クライアントに出さない

# Yahoo! ショッピング（フェーズ2以降: JANコード検索）
YAHOO_APP_ID=your-yahoo-app-id             # サーバーサイドのみ
